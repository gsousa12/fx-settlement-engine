{
  "name": "@fx-settlement-engine/idempotency-key-cleaner",
  "version": "1.0.0",
  "description": "Job that cleans up expired idempotency keys every 30 seconds",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build": "tsc --build",
    "build:watch": "tsc --build --watch",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "start:dev": "tsx watch src/index.ts",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@fx-settlement-engine/db": "workspace:*",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.11",
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@10.28.1"
}
